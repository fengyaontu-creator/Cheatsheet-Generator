# Comma-separated list of allowed CORS origins. Unset uses a dev-only
# default (localhost:5173). In production set to the public frontend
# origin, e.g.:
# CORS_ORIGINS=http://cheatsheet.norafeng.duckdns.org

# Per-process daily cap on generation requests (all ingest endpoints).
# Reset at 00:00 UTC. Acts as a cost backstop on the public URL. Default 200.
# DAILY_GENERATION_CAP=200

# Pick provider: "openrouter" (default) or "google"
LLM_PROVIDER=openrouter

# Provider-neutral model override. If unset, falls back to provider default
# (openrouter -> anthropic/claude-sonnet-4.5, google -> gemini-2.5-pro).
# LLM_MODEL=gemini-2.5-pro

# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
# Legacy name, kept for back-compat. LLM_MODEL takes precedence.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# --- Google (OpenAI-compatible endpoint) ---
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=REPLACE_ME

# Optional per-stage provider/model overrides. Leave unset to inherit the
# global LLM_PROVIDER and model. This lets cheap stages use Google directly
# while the outline stage uses OpenRouter/Claude, for example.
#
# Preferred provider-neutral names:
# LLM_PROVIDER_STAGE0=google
# LLM_MODEL_STAGE0=gemini-2.5-flash
# LLM_PROVIDER_STAGE1=google
# LLM_MODEL_STAGE1=gemini-2.5-flash-lite
# LLM_PROVIDER_STAGE2=openrouter
# LLM_MODEL_STAGE2=anthropic/claude-sonnet-4.5
# LLM_PROVIDER_STAGE3=google
# LLM_MODEL_STAGE3=gemini-2.5-flash-lite
#
# Legacy OpenRouter-only model names are still supported when that stage's
# provider is openrouter. LLM_MODEL_STAGEX takes precedence.
# OPENROUTER_MODEL_STAGE0=google/gemini-2.5-flash
# OPENROUTER_MODEL_STAGE1=google/gemini-2.5-flash-lite
# OPENROUTER_MODEL_STAGE2=anthropic/claude-sonnet-4.5
# OPENROUTER_MODEL_STAGE3=google/gemini-2.5-flash-lite
